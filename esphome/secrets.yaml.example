# =============================================================================
# secrets.yaml.example — Template ESPHome secrets
# 
# 📋 INSTRUCTIONS :
# 1. Copiez ce fichier :
#      cp esphome/secrets.yaml.example esphome/secrets.yaml
# 
# 2. Éditez esphome/secrets.yaml et renseignez vos vraies valeurs
# 
# 3. ⚠️ NE COMMITEZ JAMAIS secrets.yaml (déjà dans .gitignore)
# 
# =============================================================================

# --- Réseau Wi-Fi ---
wifi_ssid: "VOTRE_SSID_WIFI"
wifi_password: "VOTRE_MOT_DE_PASSE_WIFI"

# --- Point d'accès de secours (fallback AP) ---
# Activé automatiquement si connexion WiFi principale échoue
ap_password: "fallback-ap-password"

# --- Mot de passe OTA (Over-The-Air updates) ---
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(16))"
ota_password: "GENERER_MOT_DE_PASSE_OTA_ICI"

# --- Clé de chiffrement API Home Assistant ---
# Clé base64 de 32 octets — générée automatiquement par ESPHome lors du 1er build
# ou manuellement avec :
# python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "GENERER_CLE_API_BASE64_32_OCTETS_ICI="
