# =============================================================================
# secrets.yaml.example — Template ESPHome secrets
# Copiez ce fichier en secrets.yaml et renseignez vos vraies valeurs.
#   cp esphome/secrets.yaml.example esphome/secrets.yaml
# Le fichier secrets.yaml est dans .gitignore et ne sera jamais commité.
# =============================================================================

# Réseau Wi-Fi
wifi_ssid: "NOM_DE_VOTRE_RESEAU_WIFI"
wifi_password: "MOT_DE_PASSE_WIFI"

# Mot de passe du point d'accès de secours (fallback AP)
ap_password: "CHANGER_CE_MOT_DE_PASSE_AP"

# Mot de passe OTA (mise à jour over-the-air)
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(16))"
ota_password: "CHANGER_CE_MOT_DE_PASSE_OTA"

# Clé de chiffrement API Home Assistant (base64, 32 octets)
# Générer dans l'UI ESPHome ou avec :
# python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "CHANGER_CETTE_CLE_API_BASE64_32_OCTETS="
